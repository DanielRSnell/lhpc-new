---
export const prerender = true;
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

import Features from '@/components/sections/features';
import WorkflowDashboardMockup from '@/components/sections/workflow-dashboard-mockup';
import PartnerLogos from '@/components/sections/partner-logos';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  {/* Hero - static Astro markup for instant LCP, no JS needed */}
  <section class="section-padding relative">
    <div class="relative container">
      <div class="flex flex-col justify-between gap-10 lg:flex-row lg:items-center">
        <div class="flex max-w-3xl flex-1 flex-col items-start gap-5">
          <h1 class="text-5xl leading-none tracking-tight text-balance md:text-6xl lg:text-7xl">
            Fuse Data & Metal. <span class="text-gradient">Scale Intelligence. Maximize ROI.</span>
          </h1>
          <p class="text-muted-foreground leading-snug md:text-lg lg:text-xl">
            Contract-based orchestration software that speeds time-to-result for AI, HPC, and digital twins under your complete control.
          </p>
        </div>
        <div class="space-y-3">
          <div class="flex gap-4.5">
            <a href="/contact" class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex flex-1 items-center justify-center rounded-md px-4 py-2 text-sm font-medium md:min-w-45">Schedule a Demo</a>
            <a href="/product" class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex flex-1 items-center justify-center rounded-md border px-4 py-2 text-sm font-medium md:min-w-45">Explore The Product</a>
          </div>
          <div class="text-center text-sm">
            Partnered with NVIDIA, TD Synnex, IBM, OCI, and Mirantis &middot; Government ready
          </div>
        </div>
      </div>
      <WorkflowDashboardMockup client:interaction />
      <svg xmlns="http://www.w3.org/2000/svg" width="1342" height="1199" fill="none" class="absolute top-0 right-0 -z-10 origin-right scale-30 md:scale-50 lg:scale-100">
        <path fill="#D9D9D9" d="M914.912 1197.77 747.793 808.811l115.698-221.478 334.239 73.826 109.08 196.135-391.898 340.476Z"/>
        <path fill="url(#ha)" d="M914.912 1197.77 747.793 808.811l115.698-221.478 334.239 73.826 109.08 196.135-391.898 340.476Z"/>
        <path stroke="url(#hb)" stroke-width="0.631" d="M914.912 1197.77 747.793 808.811l115.698-221.478 334.239 73.826 109.08 196.135-391.898 340.476Z"/>
        <path fill="url(#hc)" d="m875.715 420.318 203.405-357.96c50.52-10.487-50.57 96.246 0 186.332 80.45 143.304 298.36 312.903 256.86 419.243-67.58 173.19-306.7 49.523-396.529 0-71.863-39.618-72.434-181.585-63.736-247.615Z"/>
        <path fill="url(#hd)" d="m46.623 746.37 908.336-619.388 130.381-66.714-46.89 196.709-156.685 413.622c-27.829 50.066-111.545 120.16-223.775 0-98.592-105.557-466.882-3.975-611.367 75.771L.814 777.607c10.115-9.59 25.82-20.205 45.809-31.237Z"/>
        <g filter="url(#he)"><path fill="url(#hf)" d="m883.093 595.649 164.727-565.43 4.66 326.52-169.387 238.91Z"/></g>
        <defs>
          <linearGradient id="ha" x1="1027.3" x2="1027.73" y1="587.333" y2="1198.11" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#9D83E7"/><stop offset="0.516" stop-color="#D445E7"/></linearGradient>
          <linearGradient id="hb" x1="1027.3" x2="1027.3" y1="587.333" y2="1197.77" gradientUnits="userSpaceOnUse"><stop stop-color="#10CBF4"/><stop offset="1" stop-color="#10CBF4" stop-opacity="0"/></linearGradient>
          <linearGradient id="hc" x1="871.897" x2="1188.44" y1="575.509" y2="575.628" gradientUnits="userSpaceOnUse"><stop stop-color="#9259ED"/><stop offset="0.514" stop-color="#CF54EE"/><stop offset="1" stop-color="#FB8684"/></linearGradient>
          <linearGradient id="hd" x1="676.669" x2="677.051" y1="60.268" y2="757.516" gradientUnits="userSpaceOnUse"><stop stop-color="#B956EE"/><stop offset="1" stop-color="#9672FF"/></linearGradient>
          <linearGradient id="hf" x1="1020.81" x2="814.267" y1="202.771" y2="477.618" gradientUnits="userSpaceOnUse"><stop stop-color="#FB07FF"/><stop offset="0.505" stop-color="#FF6847"/><stop offset="1" stop-color="#FF474A"/></linearGradient>
          <filter id="he" width="228.968" height="625.009" x="853.303" y="0.429" color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse"><feFlood flood-opacity="0" result="BackgroundImageFix"/><feBlend in="SourceGraphic" in2="BackgroundImageFix" result="shape"/><feGaussianBlur result="effect1_foregroundBlur" stdDeviation="14.895"/></filter>
        </defs>
      </svg>
    </div>
  </section>

  <PartnerLogos />
  <Features client:interaction />
</DefaultLayout>
